{
  "name": "pokemon-patacon-backend",
  "version": "1.0.0",
  "description": "Backend servidor Hono + Bun para Pokémon Patacon",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outfile=dist/server.js",
    "test": "bun test",
    "format": "prettier --write 'src/**/*.ts'",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "mongodb": "^6.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
