# Backend Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pokemon-patacon
MONGODB_DB_NAME=pokemon-patacon

# Clerk Authentication
# CLERK_SECRET_KEY — opcional, para APIs de administración de Clerk
# CLERK_JWT_ISSUER — issuer del JWT, formato: https://<instance>.clerk.accounts.dev
# CLERK_JWT_KEY — opcional (fallback), PEM para verificación local sin internet
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_JWT_ISSUER=https://XXXX-XXX-XXX.clerk.accounts.dev

# PokeAPI
POKEAPI_BASE_URL=https://pokeapi.co/api/v2
POKEAPI_TIMEOUT=10000

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Game Settings
ROOM_TIMEOUT_MINUTES=30
RECONNECT_TIMEOUT_SECONDS=30
TURN_TIMEOUT_SECONDS=30
DRAFT_TIMEOUT_SECONDS=60

# Server
BUN_ENV=development
